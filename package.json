{
  "name": "turkish-flashcards",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "copy-web": "node -e \"const fs=require('fs');['index.html','spanish.html','english.html','manifest.json'].forEach(f=>{try{fs.copyFileSync(f,'www/'+f)}catch(e){}});const icon=fs.existsSync('icon.png')?'icon.png':fs.existsSync('assets/icon.png')?'assets/icon.png':null;if(icon)fs.copyFileSync(icon,'www/icon.png');console.log('Copied to www/');\"",
    "build-ads": "npx esbuild ads-init.js --bundle --format=iife --global-name=AdsModule --outfile=www/ads-bundle.js",
    "generate-icons": "npx @capacitor/assets generate --ios",
    "trigger-build": "node trigger-codemagic.js",
    "sync": "npm run build-ads && npm run copy-web && npx cap sync"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pifagortradebtc/turkish-flashcards.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/pifagortradebtc/turkish-flashcards/issues"
  },
  "homepage": "https://github.com/pifagortradebtc/turkish-flashcards#readme",
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "esbuild": "^0.27.4"
  }
}
